# Production Environment Variables - Web

NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.noplace.app/api
NEXT_PUBLIC_WS_URL=wss://api.noplace.app/ws

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=${ANALYTICS_ID}

# Sentry
NEXT_PUBLIC_SENTRY_AUTH_TOKEN=${SENTRY_AUTH_TOKEN}

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_BETA=false
